{
  "entities": {
    "MenuItem": {
      "title": "Menu Item",
      "description": "A pizza or side dish on the menu",
      "type": "object",
      "properties": {
        "name": { "type": "string" },
        "description": { "type": "string" },
        "price": { "type": "number" },
        "category": { "type": "string", "enum": ["veg", "non-veg", "gluten-free"] },
        "image": { "type": "string" },
        "isSpecial": { "type": "boolean" }
      },
      "required": ["name", "price", "category"]
    },
    "Order": {
      "title": "Order",
      "description": "A customer's pizza order",
      "type": "object",
      "properties": {
        "userId": { "type": "string" },
        "items": { 
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "menuItemId": { "type": "string" },
              "name": { "type": "string" },
              "quantity": { "type": "number" },
              "price": { "type": "number" }
            }
          }
        },
        "status": { "type": "string", "enum": ["pending", "preparing", "out-for-delivery", "delivered"] },
        "total": { "type": "number" },
        "createdAt": { "type": "string", "format": "date-time" },
        "deliveryLocation": {
          "type": "object",
          "properties": {
            "address": { "type": "string" },
            "lat": { "type": "number" },
            "lng": { "type": "number" }
          }
        }
      },
      "required": ["userId", "items", "status", "total", "createdAt"]
    },
    "Review": {
      "title": "Review",
      "description": "Customer feedback",
      "type": "object",
      "properties": {
        "userId": { "type": "string" },
        "userName": { "type": "string" },
        "rating": { "type": "number" },
        "comment": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["userId", "userName", "rating", "comment", "createdAt"]
    }
  },
  "firestore": {
    "/menu": {
      "schema": "MenuItem",
      "description": "The pizza menu"
    },
    "/orders": {
      "schema": "Order",
      "description": "Customer orders"
    },
    "/reviews": {
      "schema": "Review",
      "description": "Customer reviews"
    }
  }
}
