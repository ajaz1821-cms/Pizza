rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Default deny
    match /{document=**} {
      allow read, write: if false;
    }

    // Helper functions
    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    // Validations
    function isValidMenuItem(data) {
      return data.name is string && data.name.size() <= 100 &&
             data.price is number && data.price > 0 &&
             data.category in ['veg', 'non-veg', 'gluten-free'];
    }

    function isValidOrder(data) {
      return isOwner(data.userId) &&
             data.items is list && data.items.size() > 0 &&
             data.status in ['pending', 'preparing', 'out-for-delivery', 'delivered'] &&
             data.total is number && data.total >= 0 &&
             data.createdAt == request.time;
    }

    function isValidReview(data) {
      return isOwner(data.userId) &&
             data.rating >= 1 && data.rating <= 5 &&
             data.comment is string && data.comment.size() <= 500 &&
             data.createdAt == request.time;
    }

    // Collection matches
    match /menu/{itemId} {
      allow read: if true;
      allow write: if false; // Only admin via console/internal tool for now
    }

    match /orders/{orderId} {
      allow read: if isSignedIn() && (resource.data.userId == request.auth.uid);
      allow list: if isSignedIn() && resource.data.userId == request.auth.uid;
      allow create: if isSignedIn() && isValidOrder(request.resource.data);
      allow update: if isSignedIn() && resource.data.userId == request.auth.uid && (
        // User can only update if it's still pending or they are just tracking
        request.resource.data.diff(resource.data).affectedKeys().hasOnly(['deliveryLocation'])
      );
    }

    match /reviews/{reviewId} {
      allow read: if true;
      allow create: if isSignedIn() && isValidReview(request.resource.data);
    }

    match /users/{userId} {
      allow read, write: if isOwner(userId);
    }
  }
}
